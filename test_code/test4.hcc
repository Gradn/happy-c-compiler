
// 循环嵌套

int main() {
    int arr[10];
    // 设置数组初值
    arr[0] = 9; arr[1] = 28; arr[2] = 19; arr[3] = 57; arr[4] = 89;
    arr[5] = 5; arr[6] = 45; arr[7] = 51; arr[8] = 551; arr[9] = 1;
    int i; int j; int t; int p;
    int val1; int val2; int valt;
    i = 0;
    j = 0;
    while (i < 9) {
        j = 0;
        t = 9 - i;
        while (j < t) {
            val1 = arr[j];
            val2 = arr[j + 1];
            if (val1 > val2) {
                arr[j] = val2;
                arr[j + 1] = val1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    for (p = 0; p < 10; p = p + 1) {
        valt = arr[p];
        printf("数组第%d项的值是%d\n", p, valt);
    }
}